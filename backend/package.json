{
  "name": "gestescolar-backend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "start": "node dist/api/server.js",
    "build": "esbuild api-src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=api/index.js --external:pg-native",
    "test": "tsx --test src/**/*.test.ts",
    "migrate": "tsx src/db/migrate.ts",
    "vercel-build": "esbuild api-src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=api/index.js --external:pg-native"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@types/ws": "^8.18.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "pg": "^8.13.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.21.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
