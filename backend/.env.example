# ============================================================
#  Backend GestEscolar v2 — variáveis de ambiente (NUNCA commitar .env)
# ============================================================

# --- Neon Postgres ---
# String de conexão pooled (transaction mode) — usada pelas queries da API.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.sa-east-1.aws.neon.tech/gestescolar?sslmode=require
# String direta (sem pooler) — usada para rodar migrations.
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxx.sa-east-1.aws.neon.tech/gestescolar?sslmode=require

# --- Neon Auth (valores gerados ao habilitar Neon Auth no console) ---
# Preencher conforme o que o console do Neon gerar para o seu projeto.
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# --- ASAAS (pagamentos: PIX + cartão + split) ---
# Ativa o provedor ASAAS. Sem ASAAS_API_KEY, o sistema usa o modo simulação.
ASAAS_API_KEY=
ASAAS_ENV=sandbox                 # sandbox | production
ASAAS_WEBHOOK_TOKEN=              # token do webhook (configurado no painel ASAAS)

# --- Geral ---
NODE_ENV=development
